package br.com.senai.v2;

import java.util.Random;

public class Jogo {
    Random rd = new Random();
    int tentativas;
    int raffle;

    public Jogo() {
        tentativas = 5;
        raffle = rd.nextInt(1, 101);
    }

    public int getTentativas() {
        return tentativas;
    }

    public int getRaffle() {
        return raffle;
    }
}

